{%- comment -%}
  Galim Health — What we measure (auto-scroll carousel)
  Marquee-style infinite carousel: each block is one measurement component
  (Vision, Hearing, Lung Function, etc.). No JS — pure CSS keyframe loop,
  paused on hover. Items are duplicated in the DOM so the loop is seamless.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign duration = s.speed | default: 45
-%}

<section class="gh-mq gh-section" data-gh-section="carousel" style="background: {{ s.bg_color }}; --gh-mq-duration: {{ duration }}s; --gh-side-color: {{ s.side_color | default: '#082d36' }}; --gh-side-width: {{ s.side_width | default: 12 }}%;">
  <div class="gh-container">
    {%- if s.eyebrow != blank -%}<p class="gh-eyebrow gh-mq__eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="gh-mq__h2">{{ s.heading }}</h2>{%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="gh-mq__viewport" data-gh-carousel aria-label="Measurement components">
      <div class="gh-mq__track" data-gh-track tabindex="0">
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            {%- assign b = block.settings -%}
            <div class="gh-mq__card" {{ block.shopify_attributes }}>
              <div class="gh-mq__head">
                <span class="gh-mq__icon">
                  {%- case b.icon -%}
                    {%- when 'eye' -%}{%- render 'icon-eye', size: 20 -%}
                    {%- when 'ear' -%}{%- render 'icon-ear', size: 20 -%}
                    {%- when 'lung' -%}{%- render 'icon-lung', size: 20 -%}
                    {%- when 'heartbeat' -%}{%- render 'icon-heartbeat', size: 20 -%}
                    {%- when 'brain' -%}{%- render 'icon-brain', size: 20 -%}
                    {%- when 'muscle' -%}{%- render 'icon-muscle', size: 20 -%}
                    {%- when 'skin' -%}{%- render 'icon-skin', size: 20 -%}
                    {%- when 'balance' -%}{%- render 'icon-balance', size: 20 -%}
                    {%- when 'pressure' -%}{%- render 'icon-pressure', size: 20 -%}
                    {%- when 'blood' -%}{%- render 'icon-blood', size: 20 -%}
                    {%- when 'dna' -%}{%- render 'icon-dna', size: 20 -%}
                    {%- when 'microbiome' -%}{%- render 'icon-microbiome', size: 20 -%}
                    {%- when 'mri' -%}{%- render 'icon-mri', size: 20 -%}
                    {%- when 'bolt' -%}{%- render 'icon-bolt', size: 18 -%}
                    {%- else -%}{%- render 'icon-heartbeat', size: 20 -%}
                  {%- endcase -%}
                </span>
                {%- if b.name != blank -%}<h3 class="gh-mq__name">{{ b.name }}</h3>{%- endif -%}
              </div>
              {%- if b.description != blank -%}<p class="gh-mq__desc">{{ b.description }}</p>{%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="gh-mq__sides" aria-hidden="true"></div>
    </div>

    <div class="gh-container gh-mq__progress-wrap">
      <button type="button" class="gh-mq__nav" data-gh-nav="prev" aria-label="Previous">‹</button>
      <div class="gh-mq__progress" data-gh-scrubber role="slider" aria-label="Carousel position" tabindex="0" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
        <div class="gh-mq__progress-bar" data-gh-progress></div>
        <div class="gh-mq__progress-thumb" data-gh-thumb></div>
      </div>
      <button type="button" class="gh-mq__nav" data-gh-nav="next" aria-label="Next">›</button>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .gh-mq { padding: var(--gh-pad-y) 0; overflow: hidden; }
  .gh-mq .gh-container { padding: 0 var(--gh-pad-x); }
  .gh-mq__eyebrow { margin-bottom: 12px; }
  .gh-mq__h2 { font: 200 28px/1.14 var(--gh-sans); letter-spacing: -0.02em; color: var(--gh-white); margin-bottom: 24px; max-width: 720px; }

  /* Swipeable scroll container (no more auto-marquee) */
  .gh-mq__viewport { position: relative; }
  .gh-mq__track {
    display: flex;
    gap: 10px;
    padding: 2px var(--gh-pad-x) 4px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-padding-left: var(--gh-pad-x);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .gh-mq__track::-webkit-scrollbar { display: none; }
  .gh-mq__track:focus-visible { outline: 2px solid var(--gh-green); outline-offset: 4px; border-radius: 4px; }

  .gh-mq__card {
    flex: 0 0 auto;
    width: 220px;
    padding: 16px 18px 18px;
    border-radius: 10px;
    border: 1px solid var(--gh-border);
    background: linear-gradient(160deg, var(--gh-teal-700), var(--gh-bg-900));
    color: var(--gh-light);
    display: flex; flex-direction: column; gap: 8px;
    scroll-snap-align: start;
    transition: border-color 0.25s ease;
  }
  .gh-mq__card:hover { border-color: rgba(140, 191, 138, 0.4); }

  /* Icon + name on the same line */
  .gh-mq__head { display: flex; align-items: center; gap: 10px; }
  .gh-mq__icon {
    width: 32px; height: 32px; border-radius: 8px;
    background: rgba(140, 191, 138, 0.14);
    border: 1px solid rgba(140, 191, 138, 0.3);
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--gh-green);
    flex-shrink: 0;
  }
  .gh-mq__icon svg { width: 18px; height: 18px; }
  .gh-mq__name { font: 500 15px/1.15 var(--gh-sans); color: var(--gh-white); }
  .gh-mq__desc { font: 300 12.5px/1.45 var(--gh-sans); color: var(--gh-muted); margin: 0; }

  /* Side fades */
  .gh-mq__sides { position: absolute; inset: 0; pointer-events: none; }
  .gh-mq__sides::before,
  .gh-mq__sides::after {
    content: ""; position: absolute; top: 0; bottom: 0;
    width: var(--gh-side-width, 12%);
    z-index: 2;
  }
  .gh-mq__sides::before {
    left: 0;
    background: linear-gradient(to right, var(--gh-side-color, #082d36), rgba(8, 45, 54, 0));
  }
  .gh-mq__sides::after {
    right: 0;
    background: linear-gradient(to left, var(--gh-side-color, #082d36), rgba(8, 45, 54, 0));
  }

  /* Interactive scrubber: click/drag to navigate, prev/next arrows */
  .gh-mq__progress-wrap {
    margin-top: 22px;
    display: flex; align-items: center; gap: 14px;
  }
  .gh-mq__nav {
    flex-shrink: 0;
    width: 34px; height: 34px;
    border-radius: 50%;
    border: 1px solid var(--gh-border);
    background: transparent;
    color: var(--gh-light);
    font: 300 22px/1 var(--gh-sans);
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .gh-mq__nav:hover { border-color: var(--gh-green); color: var(--gh-green); }
  .gh-mq__nav:disabled { opacity: 0.35; cursor: default; }
  .gh-mq__nav:disabled:hover { border-color: var(--gh-border); color: var(--gh-light); }

  .gh-mq__progress {
    flex: 1;
    height: 22px;               /* larger hit area than the visible bar */
    position: relative;
    display: flex;
    align-items: center;
    cursor: pointer;
    touch-action: none;
    max-width: 420px;
  }
  .gh-mq__progress::before {
    content: "";
    position: absolute; left: 0; right: 0; top: 50%;
    height: 3px;
    background: rgba(168, 194, 200, 0.16);
    border-radius: 999px;
    transform: translateY(-50%);
  }
  .gh-mq__progress-bar {
    position: absolute; left: 0; top: 50%;
    height: 3px;
    width: 0%;
    background: var(--gh-green);
    border-radius: 999px;
    transform: translateY(-50%);
    transition: width 0.15s ease-out, background 0.25s ease;
    pointer-events: none;
  }
  .gh-mq__progress-bar.is-end { background: linear-gradient(90deg, var(--gh-green), var(--gh-light)); }
  .gh-mq__progress-thumb {
    position: absolute; top: 50%;
    left: 0%;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--gh-white);
    border: 2px solid var(--gh-green);
    transform: translate(-50%, -50%);
    transition: left 0.15s ease-out, transform 0.15s ease-out;
    pointer-events: none;
    box-shadow: 0 2px 8px rgba(6, 31, 38, 0.4);
  }
  .gh-mq__progress:hover .gh-mq__progress-thumb,
  .gh-mq__progress.is-dragging .gh-mq__progress-thumb { transform: translate(-50%, -50%) scale(1.25); }
  .gh-mq__progress.is-dragging { cursor: grabbing; }
  .gh-mq__progress:focus-visible { outline: none; }
  .gh-mq__progress:focus-visible .gh-mq__progress-thumb { box-shadow: 0 0 0 4px rgba(140, 191, 138, 0.35); }

  @media (max-width: 768px) {
    .gh-mq__h2 { font-size: 22px; margin-bottom: 16px; }
    .gh-mq__card { width: 200px; padding: 14px 16px 16px; }
    .gh-mq__icon { width: 30px; height: 30px; border-radius: 7px; }
    .gh-mq__icon svg { width: 17px; height: 17px; }
    .gh-mq__name { font-size: 14px; }
    .gh-mq__desc { font-size: 12px; }
    .gh-mq__sides::before,
    .gh-mq__sides::after { width: 6%; }
    .gh-mq__progress { max-width: none; }
    .gh-mq__nav { width: 32px; height: 32px; font-size: 20px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Galim · Carousel",
  "class": "gh-section-full",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHAT WE MEASURE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Every system, in one visit." },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#082d36" },
    { "type": "range", "id": "speed", "min": 20, "max": 120, "step": 5, "unit": "s", "label": "Loop duration", "info": "Time for one full pass. Higher = slower.", "default": 45 },
    { "type": "header", "content": "Side fades" },
    { "type": "color", "id": "side_color", "label": "Side fade color", "default": "#082d36" },
    { "type": "range", "id": "side_width", "min": 0, "max": 30, "step": 2, "unit": "%", "label": "Side fade width", "default": 12 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Measurement",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          {"value":"eye","label":"Eye"},
          {"value":"ear","label":"Ear"},
          {"value":"lung","label":"Lung"},
          {"value":"heartbeat","label":"Heart"},
          {"value":"brain","label":"Brain"},
          {"value":"muscle","label":"Muscle / Strength"},
          {"value":"skin","label":"Skin"},
          {"value":"balance","label":"Balance / Posture"},
          {"value":"pressure","label":"Blood pressure"},
          {"value":"blood","label":"Blood"},
          {"value":"dna","label":"DNA"},
          {"value":"microbiome","label":"Microbiome"},
          {"value":"mri","label":"MRI / Scan"},
          {"value":"bolt","label":"Performance"}
        ], "default": "eye" },
        { "type": "text", "id": "name", "label": "Name", "default": "Vision" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Visual acuity and eye health." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Galim · Carousel",
      "blocks": [
        { "type": "item", "settings": { "icon": "eye", "name": "Vision", "description": "Visual acuity and eye health." } },
        { "type": "item", "settings": { "icon": "ear", "name": "Hearing", "description": "Auditory range and clarity." } },
        { "type": "item", "settings": { "icon": "lung", "name": "Lung function", "description": "Capacity, flow, oxygen exchange." } },
        { "type": "item", "settings": { "icon": "heartbeat", "name": "Cardiovascular", "description": "Rhythm, output, arterial health." } },
        { "type": "item", "settings": { "icon": "pressure", "name": "Blood pressure", "description": "Systolic, diastolic, arterial stiffness." } },
        { "type": "item", "settings": { "icon": "blood", "name": "Blood biomarkers", "description": "Metabolic, inflammatory, hormonal panels." } },
        { "type": "item", "settings": { "icon": "muscle", "name": "Strength", "description": "True force output, not just what you lift." } },
        { "type": "item", "settings": { "icon": "bolt", "name": "Body composition", "description": "DEXA — fat, muscle, distribution." } },
        { "type": "item", "settings": { "icon": "balance", "name": "Mobility & balance", "description": "Joint range, posture, stability." } },
        { "type": "item", "settings": { "icon": "brain", "name": "Cognition", "description": "Reaction, memory, focus." } },
        { "type": "item", "settings": { "icon": "skin", "name": "Skin", "description": "Screening for lesions and sun damage." } },
        { "type": "item", "settings": { "icon": "microbiome", "name": "Gut", "description": "Microbiome and metabolic insights." } }
      ]
    }
  ]
}
{% endschema %}
