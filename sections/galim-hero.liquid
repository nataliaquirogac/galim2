{%- comment -%}
  Galim Health — Hero
  Full-bleed image + layered dark gradients + faint grid. Text bottom-left (desktop),
  bottom over image (mobile). Primary CTA opens the waitlist modal.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign has_image = false
  if s.image != blank or s.image_url != blank
    assign has_image = true
  endif
-%}

<section id="{{ s.anchor_id | default: 'top' }}" class="gh-hero" data-gh-section="hero" style="--gh-hero-h1-max: {{ s.heading_size | default: 52 }}px; --gh-hero-h1-min: {{ s.heading_size_mobile | default: 30 }}px; --gh-hero-tint: {{ s.overlay_strength | default: 45 | divided_by: 100.0 }};">
  {%- liquid
    assign desktop_src = ''
    if s.image != blank
      assign desktop_src = s.image | image_url: width: 1800
    elsif s.image_url != blank
      assign desktop_src = s.image_url
    endif
    assign mobile_src = ''
    if s.image_mobile != blank
      assign mobile_src = s.image_mobile | image_url: width: 700
    elsif s.image_url_mobile != blank
      assign mobile_src = s.image_url_mobile
    endif
    assign main_src = desktop_src
    if main_src == blank
      assign main_src = mobile_src
    endif
  -%}
  <div class="gh-hero__media">
    {%- if main_src != blank -%}
      <picture>
        {%- if mobile_src != blank and desktop_src != blank -%}
          <source media="(max-width: 768px)" srcset="{{ mobile_src }}">
        {%- endif -%}
        <img class="gh-hero__img" src="{{ main_src }}" alt="{{ s.image.alt | escape | default: shop.name }}" loading="eager" fetchpriority="high" onerror="this.style.display='none'">
      </picture>
    {%- endif -%}
    <div class="gh-hero__tint"></div>
    <div class="gh-hero__grad-h"></div>
    <div class="gh-hero__grad-v"></div>
    <div class="gh-hero__grid"></div>
  </div>

  <div class="gh-hero__inner">
    <div class="gh-hero__col">
      {%- if s.badge != blank -%}
        <div class="gh-hero__badge">
          <span class="gh-hero__dot"></span>{{ s.badge }}
        </div>
      {%- endif -%}

      {%- if s.heading != blank or s.heading_accent != blank -%}
        <h1 class="gh-hero__h1">
          {{- s.heading | newline_to_br -}}
          {%- if s.heading_accent != blank -%}
            {%- if s.heading != blank -%}<br>{%- endif -%}
            <span class="gh-hero__h1-accent">{{ s.heading_accent }}</span>
          {%- endif -%}
        </h1>
      {%- endif -%}

      {%- if s.subheading != blank -%}
        <p class="gh-hero__sub">{{ s.subheading }}</p>
      {%- endif -%}

      {%- if s.council_line != blank -%}
        <p class="gh-hero__council">{{ s.council_line }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="gh-hero__plans">
          {%- for block in section.blocks -%}
            {%- if block.type == 'plan' -%}
              {%- liquid
                assign plan_href = block.settings.link
                if plan_href == blank
                  assign plan_href = '#plans'
                endif
              -%}
              <a href="{{ plan_href }}" class="gh-hero__plan" {{ block.shopify_attributes }}>
                {%- if block.settings.time != blank -%}<span class="gh-hero__plan-time">{{ block.settings.time }}</span>{%- endif -%}
                {%- if block.settings.name != blank -%}<span class="gh-hero__plan-name">{{ block.settings.name }}</span>{%- endif -%}
                {%- if block.settings.price != blank -%}<span class="gh-hero__plan-price">{{ block.settings.price }}</span>{%- endif -%}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="gh-hero__actions">
        {%- if s.button_label != blank -%}
          {%- if s.button_opens_modal -%}
            <a href="#" class="gh-btn gh-btn--solid" data-gh-waitlist-open>{{ s.button_label }} →</a>
          {%- else -%}
            <a href="{{ s.button_link | default: '#' }}" class="gh-btn gh-btn--solid">{{ s.button_label }} →</a>
          {%- endif -%}
        {%- endif -%}
        {%- if s.coords != blank -%}
          <span class="gh-hero__coords">{{ s.coords }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .gh-hero {
    position: relative;
    min-height: 940px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--gh-bg-900);
  }
  .gh-hero__media { position: absolute; inset: 0; overflow: hidden; }
  .gh-hero__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  /* Full-cover teal tint: pulls any photo into the brand palette; strength is a customizer slider */
  .gh-hero__tint { position: absolute; inset: 0; background: rgb(8 45 54 / var(--gh-hero-tint, 0.45)); }
  /* Diagonal scrim: darkest at the bottom-right, fades out toward top-left */
  .gh-hero__grad-h {
    position: absolute; inset: 0;
    background: linear-gradient(305deg,
      rgba(6,31,38,.97) 0%,
      rgba(6,31,38,.85) 26%,
      rgba(6,31,38,.35) 52%,
      rgba(6,31,38,0) 72%);
  }
  .gh-hero__grad-v { position: absolute; inset: 0; display: none; }
  .gh-hero__grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(rgba(214,224,226,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(214,224,226,.05) 1px, transparent 1px);
    background-size: 64px 64px;
    -webkit-mask-image: radial-gradient(80% 90% at 75% 50%, #000, transparent);
    mask-image: radial-gradient(80% 90% at 75% 50%, #000, transparent);
  }
  .gh-hero__inner { position: relative; width: 100%; max-width: var(--gh-max); margin: 0 auto; padding: 0 64px; display: flex; justify-content: flex-end; }
  .gh-hero__col { max-width: 600px; }
  .gh-hero__badge {
    display: inline-flex; align-items: center; gap: 10px;
    font: 500 11px/1 var(--gh-mono); letter-spacing: 0.24em; color: var(--gh-light);
    margin-bottom: 26px;
  }
  .gh-hero__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--gh-green); display: inline-block; animation: gh-blink 1.6s infinite; }
  .gh-hero__h1 { font: 200 clamp(var(--gh-hero-h1-min, 30px), 4vw, var(--gh-hero-h1-max, 52px))/1.1 var(--gh-sans); letter-spacing: -0.02em; color: var(--gh-white); margin-bottom: 22px; text-shadow: 0 1px 2px rgba(6,31,38,.35), 0 6px 32px rgba(6,31,38,.45); }
  .gh-hero__h1-accent { font-weight: 500; }
  .gh-hero__sub { font: 300 19px/1.55 var(--gh-sans); color: var(--gh-light); max-width: 520px; margin-bottom: 30px; text-shadow: 0 1px 2px rgba(6,31,38,.4), 0 4px 22px rgba(6,31,38,.4); }
  .gh-hero__council { font: 400 15px/1.5 var(--gh-sans); color: var(--gh-muted); max-width: 520px; margin-bottom: 30px; text-shadow: 0 1px 2px rgba(6,31,38,.4); }
  .gh-hero__actions { display: flex; gap: 18px; align-items: center; flex-wrap: wrap; }
  .gh-hero__coords { font: 400 13px/1 var(--gh-mono); letter-spacing: 0.06em; color: var(--gh-muted); }

  /* Plans: on desktop a single quiet mono line above the CTA */
  .gh-hero__plans { display: flex; flex-wrap: wrap; gap: 12px 34px; margin: 0 0 28px; }
  .gh-hero__plan {
    display: inline-flex; align-items: baseline; gap: 9px;
    font: 400 12px/1 var(--gh-mono); letter-spacing: 0.1em;
    color: var(--gh-muted); text-transform: uppercase;
    transition: color 0.25s ease;
  }
  .gh-hero__plan:hover { color: var(--gh-green); }
  .gh-hero__plan:hover .gh-hero__plan-price { color: var(--gh-green); }
  .gh-hero__plan-time { color: inherit; white-space: nowrap; }
  .gh-hero__plan-name { color: inherit; }
  .gh-hero__plan-price { color: var(--gh-light); white-space: nowrap; transition: color 0.25s ease; }
  .gh-hero__plan-price::before { content: "· "; color: var(--gh-slate); }

  @media (max-width: 600px) {
    /* Immersive minimal: full-screen photo, bottom gradient, text bottom-left */
    .gh-hero  .gh-hero {
    min-height: auto;
    align-items: flex-start;
  }

  .gh-hero__inner {
    padding: 50px 20px 24px;
    justify-content: flex-start;
  }
}
    .gh-hero__grad-h,
    .gh-hero__grid { display: none; }
    .gh-hero__tint { background: rgb(8 45 54 / calc(var(--gh-hero-tint, 0.45) * 0.4)); }
    .gh-hero__grad-v {
      display: block;
      background: linear-gradient(180deg,
        rgba(6,31,38,.5) 0%,
        rgba(6,31,38,0) 38%,
        rgba(6,31,38,.8) 66%,
        rgba(6,31,38,.98) 100%);
    }
    .gh-hero__inner { padding: 0 20px 24px; justify-content: flex-start; }
    .gh-hero__col { max-width: none; width: 100%; }
    .gh-hero__badge { font-size: 10px; letter-spacing: 0.2em; margin-bottom: 16px; }
    .gh-hero__dot { width: 6px; height: 6px; }
    .gh-hero__h1 { line-height: 1.08; margin-bottom: 14px; }
    .gh-hero__h1-accent { font-weight: inherit; }
    .gh-hero__sub { font-size: 16px; margin-bottom: 24px; }
    .gh-hero__council { font-size: 13px; margin-bottom: 24px; }
    .gh-hero__coords { display: none; }

    /* Plans become minimal hairline rows */
    .gh-hero__plans { display: block; margin: 0 0 18px; border-top: 1px solid rgba(214,224,226,.16); }
    .gh-hero__plan {
      display: flex; width: 100%; align-items: center; gap: 14px;
      padding: 15px 2px;
      border-bottom: 1px solid rgba(214,224,226,.16);
      text-transform: none; letter-spacing: 0;
    }
    .gh-hero__plan-time { font: 400 12px/1 var(--gh-mono); letter-spacing: 0.08em; color: var(--gh-muted); }
    .gh-hero__plan-name { flex: 1; font: 300 17px/1.25 var(--gh-sans); color: var(--gh-light); }
    .gh-hero__plan-price { font: 400 16px/1 var(--gh-mono); color: var(--gh-light); }
    .gh-hero__plan-price::before { content: ""; }

    .gh-hero__actions { width: 100%; }
    .gh-btn--solid { width: 100%; justify-content: center; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Galim · Hero",
  "class": "gh-section-full",
  "settings": [
    { "type": "header", "content": "Background image" },
    { "type": "image_picker", "id": "image", "label": "Hero image (desktop)" },
    { "type": "text", "id": "image_url", "label": "…or desktop image URL", "info": "Used if no image is uploaded. Falls back to a dark panel.", "default": "https://galimhealth.com/cdn/shop/files/Escena_65.png?v=1784139814&width=1600" },
    { "type": "image_picker", "id": "image_mobile", "label": "Hero image (mobile)", "info": "Shown below 768px. If empty, the desktop image is used." },
    { "type": "text", "id": "image_url_mobile", "label": "…or mobile image URL" },
    { "type": "range", "id": "overlay_strength", "min": 0, "max": 90, "step": 5, "unit": "%", "label": "Image overlay strength (desktop)", "info": "Teal tint over the whole photo. Keep low so the photo shows; the diagonal scrim already darkens the text side.", "default": 20 },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "anchor_id", "label": "Anchor id", "default": "top" },
    { "type": "range", "id": "heading_size", "min": 36, "max": 88, "step": 2, "unit": "px", "label": "Heading size (desktop)", "default": 52 },
    { "type": "range", "id": "heading_size_mobile", "min": 22, "max": 46, "step": 2, "unit": "px", "label": "Heading size (mobile)", "default": 30 },
    { "type": "text", "id": "badge", "label": "Badge (mono)", "default": "PREVENTIVE HEALTHCARE · MEDICAL COUNCIL" },
    { "type": "textarea", "id": "heading", "label": "Headline", "default": "Understand your body." },
    { "type": "text", "id": "heading_accent", "label": "Headline accent (bolder line)", "default": "Protect your future." },
    { "type": "textarea", "id": "subheading", "label": "Subheadline", "default": "Galim is a new category of preventive healthcare — combining advanced diagnostics, AI, and physician expertise into one comprehensive health assessment." },
    { "type": "textarea", "id": "council_line", "label": "Council line", "default": "Developed by our Medical Council of specialists across every major body system." },
    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join the waitlist" },
    { "type": "checkbox", "id": "button_opens_modal", "label": "Button opens waitlist modal", "default": true },
    { "type": "url", "id": "button_link", "label": "Button link (if not modal)" },
    { "type": "text", "id": "coords", "label": "Coordinates line (mono)", "default": "CALZADA DEL VALLE · MONTERREY MX" }
  ],
  "blocks": [
    {
      "type": "plan",
      "name": "Plan chip",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "time", "label": "Time (mono)", "default": "25 MIN" },
        { "type": "text", "id": "name", "label": "Name", "default": "Performance" },
        { "type": "text", "id": "price", "label": "Price", "default": "$1,499" },
        { "type": "url", "id": "link", "label": "Link", "info": "Defaults to the Protocols section (#plans)." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Galim · Hero",
      "blocks": [
        { "type": "plan", "settings": { "time": "25 MIN", "name": "Performance", "price": "$1,499" } },
        { "type": "plan", "settings": { "time": "50 MIN", "name": "Performance + Longevity", "price": "$4,999" } }
      ]
    }
  ]
}
{% endschema %}


