{%- comment -%}
  Galim Health — Hero
  Full-bleed image + layered dark gradients + faint grid. Text bottom-left (desktop),
  bottom over image (mobile). Primary CTA opens the waitlist modal.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign has_image = false
  if s.image != blank or s.image_url != blank
    assign has_image = true
  endif
-%}

<section id="{{ s.anchor_id | default: 'top' }}" class="gh-hero" data-gh-section="hero" style="--gh-hero-h1-max: {{ s.heading_size | default: 52 }}px; --gh-hero-h1-min: {{ s.heading_size_mobile | default: 30 }}px; --gh-hero-tint: {{ s.overlay_strength | default: 45 | divided_by: 100.0 }}; --gh-side-color: {{ s.side_color | default: '#092e2b' }}; --gh-side-width: {{ s.side_width | default: 22 }}%;">
  {%- liquid
    assign desktop_src = ''
    if s.image != blank
      assign desktop_src = s.image | image_url: width: 1800
    elsif s.image_url != blank
      assign desktop_src = s.image_url
    endif
    assign mobile_src = ''
    if s.image_mobile != blank
      assign mobile_src = s.image_mobile | image_url: width: 700
    elsif s.image_url_mobile != blank
      assign mobile_src = s.image_url_mobile
    endif
    assign main_src = desktop_src
    if main_src == blank
      assign main_src = mobile_src
    endif
  -%}
  <div class="gh-hero__media">
    {%- if main_src != blank -%}
      <picture>
        {%- if mobile_src != blank and desktop_src != blank -%}
          <source media="(max-width: 768px)" srcset="{{ mobile_src }}">
        {%- endif -%}
        <img class="gh-hero__img" src="{{ main_src }}" alt="{{ s.image.alt | escape | default: shop.name }}" loading="eager" fetchpriority="high" onerror="this.style.display='none'">
      </picture>
    {%- endif -%}
    <div class="gh-hero__tint"></div>
    <div class="gh-hero__grad-h"></div>
    <div class="gh-hero__grad-v"></div>
    <div class="gh-hero__grid"></div>
    <div class="gh-hero__sides" aria-hidden="true"></div>
  </div>

  <div class="gh-hero__inner">
    <div class="gh-hero__col">
      {%- if s.badge != blank -%}
        <div class="gh-hero__badge">
          <span class="gh-hero__dot"></span>{{ s.badge }}
        </div>
      {%- endif -%}

      {%- if s.heading != blank or s.heading_accent != blank -%}
        <h1 class="gh-hero__h1">
          {{- s.heading | newline_to_br -}}
          {%- if s.heading_accent != blank -%}
            {%- if s.heading != blank -%}<br>{%- endif -%}
            <span class="gh-hero__h1-accent">{{ s.heading_accent }}</span>
          {%- endif -%}
        </h1>
      {%- endif -%}

      {%- if s.subheading != blank -%}
        <p class="gh-hero__sub">{{ s.subheading }}</p>
      {%- endif -%}

      {%- if s.council_line != blank -%}
        <p class="gh-hero__council">{{ s.council_line }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="gh-hero__plans">
          {%- for block in section.blocks -%}
            {%- if block.type == 'plan' -%}
              {%- liquid
                assign plan_href = block.settings.link
                if plan_href == blank
                  assign plan_href = '#plans'
                endif
              -%}
              <a href="{{ plan_href }}" class="gh-hero__plan" {{ block.shopify_attributes }}>
                {%- if block.settings.time != blank -%}<span class="gh-hero__plan-time">{{ block.settings.time }}</span>{%- endif -%}
                {%- if block.settings.name != blank -%}<span class="gh-hero__plan-name">{{ block.settings.name }}</span>{%- endif -%}
                {%- if block.settings.price != blank -%}<span class="gh-hero__plan-price">{{ block.settings.price }}</span>{%- endif -%}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="gh-hero__actions">
        {%- if s.button_label != blank -%}
          {%- if s.button_opens_modal -%}
            <a href="#" class="gh-btn gh-btn--solid" data-gh-waitlist-open>{{ s.button_label }} →</a>
          {%- else -%}
            <a href="{{ s.button_link | default: '#' }}" class="gh-btn gh-btn--solid">{{ s.button_label }} →</a>
          {%- endif -%}
        {%- endif -%}
        {%- if s.coords != blank -%}
          <span class="gh-hero__coords">{{ s.coords }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  /* Galim Health — Hero
     Desktop: content bottom-right, 305° diagonal scrim.
     Mobile:  content bottom-left, 180° vertical scrim. */

  .gh-hero {
    position: relative;
    min-height: 704px;
    overflow: hidden;
    background: var(--gh-bg-900);
  }
  .gh-hero__media { position: absolute; inset: 0; overflow: hidden; }
  .gh-hero__img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: 0% 30%;
  }
  /* Optional teal tint over the full photo (customizer slider) */
  .gh-hero__tint { position: absolute; inset: 0; background: rgb(9 46 43 / var(--gh-hero-tint, 0.2)); pointer-events: none; }
  /* THE EFFECT: diagonal scrim over the photo */
  .gh-hero__grad-h {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(305deg,
      rgba(9, 46, 43, 0.97) 0%,
      rgba(9, 46, 43, 0.85) 26%,
      rgba(9, 46, 43, 0.35) 52%,
      rgba(9, 46, 43, 0) 72%);
  }
  .gh-hero__grad-v { position: absolute; inset: 0; display: none; pointer-events: none; }
  .gh-hero__grid { display: none; }

  /* Side fades: brand color at the edges, transparent toward the center */
  .gh-hero__sides { position: absolute; inset: 0; pointer-events: none; z-index: 2; }
  .gh-hero__sides::before,
  .gh-hero__sides::after {
    content: "";
    position: absolute; top: 0; bottom: 0;
    width: var(--gh-side-width, 22%);
    pointer-events: none;
  }
  .gh-hero__sides::before {
    left: 0;
    background: linear-gradient(to right, var(--gh-side-color, #092e2b), rgba(9,46,43,0));
  }
  .gh-hero__sides::after {
    right: 0;
    background: linear-gradient(to left, var(--gh-side-color, #092e2b), rgba(9,46,43,0));
  }

  /* Content: absolute bottom-right on desktop */
  .gh-hero__inner {
    position: absolute; right: 56px; bottom: 52px;
    width: 540px; max-width: calc(100% - 80px);
    color: #f6f5ee;
  }
  .gh-hero__col { display: block; }

  .gh-hero__badge {
    display: inline-flex; align-items: center; gap: 9px;
    font: 500 12px/1 var(--gh-mono);
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gh-green);
  }
  .gh-hero__dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gh-green); display: inline-block; }

  .gh-hero__h1 {
    margin: 22px 0 0;
    font: 300 clamp(var(--gh-hero-h1-min, 30px), 4vw, var(--gh-hero-h1-max, 56px))/1.02 var(--gh-sans);
    letter-spacing: -0.025em;
    color: #f6f5ee;
  }
  .gh-hero__h1-accent { font-weight: 500; }
  .gh-hero__sub {
    margin: 20px 0 30px; max-width: 430px;
    font: 300 18px/1.5 var(--gh-sans);
    color: rgba(246, 245, 238, 0.82);
  }
  .gh-hero__council { display: none; }
  .gh-hero__coords { display: none; }

  /* Plans as one mono line with `·` separators */
  .gh-hero__plans {
    list-style: none; margin: 0 0 24px; padding: 0;
    display: flex; flex-wrap: wrap; gap: 8px 22px;
    font: 400 12px/1 var(--gh-mono);
    letter-spacing: 0.06em;
    color: rgba(246, 245, 238, 0.75);
  }
  .gh-hero__plan {
    display: inline-flex; align-items: baseline; gap: 8px;
    color: inherit;
    transition: color 0.2s ease;
  }
  .gh-hero__plan:hover { color: #f6f5ee; }
  .gh-hero__plan-time { color: var(--gh-green); text-transform: uppercase; white-space: nowrap; }
  .gh-hero__plan-name { color: inherit; text-transform: uppercase; }
  .gh-hero__plan-name::before { content: " · "; color: inherit; }
  .gh-hero__plan-price { color: inherit; white-space: nowrap; }
  .gh-hero__plan-price::before { content: " · "; color: inherit; }

  /* Solid cream button */
  .gh-hero__actions { display: flex; gap: 18px; align-items: center; flex-wrap: wrap; }
  .gh-hero .gh-btn--solid {
    background: #eeecdf;
    color: #0c3a37;
    padding: 16px 28px;
    border-radius: 3px;
    font: 400 16px/1 var(--gh-sans);
    letter-spacing: 0;
    text-shadow: none;
  }
  .gh-hero .gh-btn--solid:hover { background: #f6f5ee; color: #0c3a37; }

  /* MOBILE (5c): vertical scrim + bottom-left content */
  @media (max-width: 768px) {
    .gh-hero { min-height: 100vh; min-height: 100svh; }
    .gh-hero__img { object-position: 20% 25%; }
    .gh-hero__tint { display: none; }
    .gh-hero__grad-h { display: none; }
    /* Narrower side fades on mobile so the photo shows more */
    .gh-hero__sides::before,
    .gh-hero__sides::after { width: 12%; }
    .gh-hero__grad-v {
      display: block;
      background: linear-gradient(180deg,
        rgba(9, 46, 43, 0.5) 0%,
        rgba(9, 46, 43, 0) 38%,
        rgba(9, 46, 43, 0.8) 66%,
        rgba(9, 46, 43, 0.98) 100%);
    }
    .gh-hero__inner { left: 22px; right: 22px; bottom: 26px; width: auto; max-width: none; }
    .gh-hero__h1 { font-size: 38px; line-height: 1.05; margin-top: 18px; }
    .gh-hero__sub { font-size: 15px; margin: 16px 0 22px; }
    .gh-hero__plans { flex-wrap: wrap; gap: 10px 18px; margin-bottom: 22px; }
    .gh-hero .gh-btn--solid { width: 100%; justify-content: center; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Galim · Hero",
  "class": "gh-section-full",
  "settings": [
    { "type": "header", "content": "Background image" },
    { "type": "image_picker", "id": "image", "label": "Hero image (desktop)" },
    { "type": "text", "id": "image_url", "label": "…or desktop image URL", "info": "Used if no image is uploaded. Falls back to a dark panel.", "default": "https://galimhealth.com/cdn/shop/files/Escena_65.png?v=1784139814&width=1600" },
    { "type": "image_picker", "id": "image_mobile", "label": "Hero image (mobile)", "info": "Shown below 768px. If empty, the desktop image is used." },
    { "type": "text", "id": "image_url_mobile", "label": "…or mobile image URL" },
    { "type": "range", "id": "overlay_strength", "min": 0, "max": 90, "step": 5, "unit": "%", "label": "Image overlay strength (desktop)", "info": "Teal tint over the whole photo. Keep low so the photo shows; the diagonal scrim already darkens the text side.", "default": 20 },
    { "type": "color", "id": "side_color", "label": "Side fade color", "info": "Color that fades in from the left and right edges over the photo.", "default": "#092e2b" },
    { "type": "range", "id": "side_width", "min": 0, "max": 40, "step": 2, "unit": "%", "label": "Side fade width", "default": 22 },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "anchor_id", "label": "Anchor id", "default": "top" },
    { "type": "range", "id": "heading_size", "min": 36, "max": 88, "step": 2, "unit": "px", "label": "Heading size (desktop)", "default": 52 },
    { "type": "range", "id": "heading_size_mobile", "min": 22, "max": 46, "step": 2, "unit": "px", "label": "Heading size (mobile)", "default": 30 },
    { "type": "text", "id": "badge", "label": "Badge (mono)", "default": "PREVENTIVE HEALTHCARE · MEDICAL COUNCIL" },
    { "type": "textarea", "id": "heading", "label": "Headline", "default": "Understand your body." },
    { "type": "text", "id": "heading_accent", "label": "Headline accent (bolder line)", "default": "Protect your future." },
    { "type": "textarea", "id": "subheading", "label": "Subheadline", "default": "Galim is a new category of preventive healthcare — combining advanced diagnostics, AI, and physician expertise into one comprehensive health assessment." },
    { "type": "textarea", "id": "council_line", "label": "Council line", "default": "Developed by our Medical Council of specialists across every major body system." },
    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join the waitlist" },
    { "type": "checkbox", "id": "button_opens_modal", "label": "Button opens waitlist modal", "default": true },
    { "type": "url", "id": "button_link", "label": "Button link (if not modal)" },
    { "type": "text", "id": "coords", "label": "Coordinates line (mono)", "default": "CALZADA DEL VALLE · MONTERREY MX" }
  ],
  "blocks": [
    {
      "type": "plan",
      "name": "Plan chip",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "time", "label": "Time (mono)", "default": "25 MIN" },
        { "type": "text", "id": "name", "label": "Name", "default": "Performance" },
        { "type": "text", "id": "price", "label": "Price", "default": "$1,499" },
        { "type": "url", "id": "link", "label": "Link", "info": "Defaults to the Protocols section (#plans)." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Galim · Hero",
      "blocks": [
        { "type": "plan", "settings": { "time": "25 MIN", "name": "Performance", "price": "$1,499" } },
        { "type": "plan", "settings": { "time": "50 MIN", "name": "Performance + Longevity", "price": "$4,999" } }
      ]
    }
  ]
}
{% endschema %}


