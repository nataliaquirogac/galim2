{%- comment -%}
  Galim Health — Steps ("Measure. Understand. Improve.")
  Giant stacked words that light up in sequence (scanner-style loop),
  followed by a supporting paragraph. Words are repeatable blocks.
{%- endcomment -%}

{%- liquid assign s = section.settings -%}

<section class="gh-steps gh-section" data-gh-section="steps" style="background: {{ s.bg_color }}; --gh-steps-count: {{ section.blocks.size | at_least: 1 }};">
  <div class="gh-container">
    {%- if s.eyebrow != blank -%}<p class="gh-eyebrow gh-steps__eyebrow">{{ s.eyebrow }}</p>{%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <h2 class="gh-steps__words">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' and block.settings.word != blank -%}
            <span class="gh-steps__word" style="--gh-step-i: {{ forloop.index0 }};" {{ block.shopify_attributes }}>
              <span class="gh-steps__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>{{ block.settings.word }}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </h2>
    {%- endif -%}

    {%- if s.body != blank -%}<p class="gh-steps__body">{{ s.body }}</p>{%- endif -%}
  </div>
</section>

{% stylesheet %}
  /* Centered statement moment with an ambient glow behind it */
  .gh-steps { position: relative; overflow: hidden; padding: 120px 40px; text-align: center; }
  .gh-steps::before {
    content: "";
    position: absolute; left: 50%; top: 50%;
    width: 900px; height: 620px; transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(19, 94, 115, 0.55), rgba(19, 94, 115, 0) 68%);
    filter: blur(20px);
    pointer-events: none;
  }
  .gh-steps .gh-container { position: relative; max-width: 920px; }
  .gh-steps__eyebrow { margin: 0 0 28px; }

  .gh-steps__words { display: flex; flex-direction: column; align-items: center; gap: 4px; margin-bottom: 32px; }
  .gh-steps__word {
    position: relative;
    display: flex; align-items: baseline; gap: 10px;
    font: 200 clamp(44px, 6vw, 84px)/1.12 var(--gh-sans);
    letter-spacing: -0.03em;
    color: var(--gh-light);
    animation: gh-step-cycle calc(var(--gh-steps-count, 3) * 2.4s) ease-in-out infinite;
    animation-delay: calc(var(--gh-step-i, 0) * 2.4s);
  }
  .gh-steps__num { font: 500 13px/1 var(--gh-mono); letter-spacing: 0.14em; color: currentColor; opacity: 0.75; }
  @keyframes gh-step-cycle {
    0% { color: var(--gh-slate); }
    7%, 26% { color: var(--gh-white); }
    38%, 100% { color: var(--gh-slate); }
  }

  /* Big elegant statement (used when the animated words are off) */
  .gh-steps__body {
    font: 200 clamp(28px, 3.4vw, 44px)/1.28 var(--gh-sans);
    letter-spacing: -0.02em;
    color: var(--gh-light);
    max-width: 900px; margin: 0 auto;
    text-shadow: 0 2px 30px rgba(6, 31, 38, 0.4);
  }

  @media (max-width: 768px) {
    .gh-steps { padding: 56px 20px; }
    .gh-steps::before { width: 520px; height: 420px; }
    .gh-steps__eyebrow { margin-bottom: 20px; font-size: 10px; letter-spacing: 0.24em; }
    .gh-steps__words { margin-bottom: 24px; }
    .gh-steps__word { gap: 12px; line-height: 1.18; }
    .gh-steps__num { font-size: 11px; }
    .gh-steps__body { font-size: 24px; line-height: 1.3; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Galim · Steps",
  "class": "gh-section-full",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "02 / ONE VISIT" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "In one visit, you'll understand your body more clearly than ever before — and leave knowing exactly what to improve next." },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0D3B46" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Word",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "word", "label": "Word", "default": "Measure." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Galim · Steps",
      "blocks": [
        { "type": "step", "settings": { "word": "Measure." } },
        { "type": "step", "settings": { "word": "Understand." } },
        { "type": "step", "settings": { "word": "Improve." } }
      ]
    }
  ]
}
{% endschema %}
