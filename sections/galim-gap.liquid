{%- comment -%}
  Galim Health — 01 / THE GAP
  Eyebrow, green check chip, big wt200 headline (bold = highlighted words), body.
{%- endcomment -%}

{%- liquid assign s = section.settings -%}

<section class="gh-gap gh-section" data-gh-section="gap" style="background: {{ s.bg_color }};">
  <div class="gh-container">
    {%- if s.eyebrow != blank -%}<p class="gh-eyebrow gh-gap__eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
    {%- if s.chip_label != blank -%}
      <div class="gh-gap__chip">
        <span class="gh-gap__check">✓</span>
        <span class="gh-gap__chip-label">{{ s.chip_label }}</span>
      </div>
    {%- endif -%}
    {%- if s.heading != blank -%}<h2 class="gh-gap__h2">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.body != blank -%}<p class="gh-gap__body">{{ s.body }}</p>{%- endif -%}
  </div>
</section>

{% stylesheet %}
  .gh-gap { border-top: 1px solid rgba(168,194,200,.1); }
  .gh-gap__eyebrow { margin-bottom: 44px; }
  .gh-gap__chip { display: inline-flex; align-items: center; gap: 12px; margin-bottom: 28px; }
  .gh-gap__check {
    width: 26px; height: 26px; border-radius: 50%; background: var(--gh-green);
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--gh-bg); font: 600 14px/1 var(--gh-sans); flex-shrink: 0;
  }
  .gh-gap__chip-label { font: 500 12px/1 var(--gh-mono); letter-spacing: 0.2em; color: var(--gh-green); }
  .gh-gap__h2 { font: 200 52px/1.12 var(--gh-sans); letter-spacing: -0.02em; color: var(--gh-white); max-width: 1000px; margin-bottom: 28px; }
  .gh-gap__h2 strong { color: var(--gh-light); font-weight: 500; }
  .gh-gap__body { font: 300 19px/1.6 var(--gh-sans); color: var(--gh-light); max-width: 760px; }
  .gh-gap__body p { margin: 0; }

  @media (max-width: 768px) {
    .gh-gap__eyebrow { margin-bottom: 22px; font-size: 10px; letter-spacing: 0.24em; }
    .gh-gap__chip { gap: 10px; margin-bottom: 20px; }
    .gh-gap__check { width: 24px; height: 24px; font-size: 13px; }
    .gh-gap__chip-label { font-size: 10px; letter-spacing: 0.18em; }
    .gh-gap__h2 { font-size: 30px; line-height: 1.15; margin-bottom: 18px; }
    .gh-gap__body { font-size: 15px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Galim · The Gap",
  "class": "gh-section-full",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "01 / THE GAP" },
    { "type": "text", "id": "chip_label", "label": "Check chip label", "default": "GALIM MEASURES" },
    { "type": "richtext", "id": "heading", "label": "Headline (bold = highlighted)", "default": "<p>Understand how your body <strong>performs today</strong>, where your biggest <strong>future risks</strong> are, and exactly what to do next.</p>" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Thousands of measurements help identify potential future risks, long before they become obvious. One personalized roadmap, powered by AI.</p>" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#082d36" }
  ],
  "presets": [{ "name": "Galim · The Gap" }]
}
{% endschema %}
