{%- comment -%}
  Galim Health — The Galim Method
  Grid-masked gradient bg, eyebrow, wt200 headline (bold = highlight), paragraphs, outline CTA.
{%- endcomment -%}

{%- liquid assign s = section.settings -%}

<section id="{{ s.anchor_id | default: 'method' }}" class="gh-method gh-section" data-gh-section="method">
  <div class="gh-method__grid"></div>
  <div class="gh-container gh-method__inner">
    {%- if s.eyebrow != blank -%}<p class="gh-eyebrow gh-method__eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="gh-method__h2">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.body_1 != blank -%}<p class="gh-method__p gh-method__p--muted">{{ s.body_1 }}</p>{%- endif -%}
    {%- if s.body_2 != blank -%}<p class="gh-method__p gh-method__p--light">{{ s.body_2 }}</p>{%- endif -%}
    {%- if s.button_label != blank -%}
      <a href="{{ s.button_link | default: '/pages/como-funciona' }}" class="gh-btn gh-btn--outline">{{ s.button_label }} →</a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .gh-method { position: relative; padding: 130px 40px; background: linear-gradient(160deg, var(--gh-bg-900), var(--gh-bg)); overflow: hidden; }
  .gh-method__grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(rgba(168,194,200,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(168,194,200,.05) 1px, transparent 1px);
    background-size: 64px 64px;
    -webkit-mask-image: radial-gradient(80% 70% at 30% 40%, #000, transparent);
    mask-image: radial-gradient(80% 70% at 30% 40%, #000, transparent);
  }
  .gh-method__inner { position: relative; max-width: 900px; }
  .gh-method__eyebrow { color: var(--gh-muted); margin-bottom: 32px; }
  .gh-method__h2 { font: 200 56px/1.08 var(--gh-sans); letter-spacing: -0.025em; color: var(--gh-white); margin-bottom: 32px; }
  .gh-method__h2 strong { color: var(--gh-light); font-weight: 500; }
  .gh-method__p { font: 300 20px/1.6 var(--gh-sans); }
  .gh-method__p--muted { color: var(--gh-muted); margin-bottom: 20px; }
  .gh-method__p--light { color: var(--gh-light); margin-bottom: 40px; }

  @media (max-width: 768px) {
    .gh-method { padding: 64px 20px; }
    .gh-method__grid { display: none; }
    .gh-method__eyebrow { margin-bottom: 22px; font-size: 10px; letter-spacing: 0.24em; }
    .gh-method__h2 { font-size: 34px; margin-bottom: 22px; }
    .gh-method__p { font-size: 16px; }
    .gh-method__p--muted { margin-bottom: 16px; }
    .gh-method__p--light { margin-bottom: 28px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Galim · Method",
  "class": "gh-section-full",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor id", "default": "method" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "THE GALIM METHOD" },
    { "type": "richtext", "id": "heading", "label": "Headline (bold = highlight)", "default": "<p>We don't just measure. <strong>We optimize</strong> — exactly to your body.</p>" },
    { "type": "textarea", "id": "body_1", "label": "Paragraph 1", "default": "A scan is a starting point, not a product. Our method turns every data point — your heart, your blood, your composition, your mobility — into a plan made only for you." },
    { "type": "textarea", "id": "body_2", "label": "Paragraph 2", "default": "With every visit, we measure again. And the plan evolves with you." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Discover the method" },
    { "type": "url", "id": "button_link", "label": "Button link", "info": "Defaults to /pages/como-funciona if left blank." }
  ],
  "presets": [{ "name": "Galim · Method" }]
}
{% endschema %}
