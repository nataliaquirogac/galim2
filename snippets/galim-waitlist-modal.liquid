{%- comment -%}
  Galim Health — Waitlist modal
  Rendered once globally by the header. Opened via [data-gh-waitlist-open].
  Fields: nombre, apellido, celular, email, ¿cómo te enteraste de nosotros?

  Wiring:
  - If settings.waitlist_form_action is blank -> Shopify native customer form.
    Creates the customer with first/last name + email; the referral source is
    saved as a tag (e.g. "waitlist, un-doctor") and, together with the phone,
    into the customer note (packed by galim.js on submit).
  - If a URL is provided -> a plain form posts there
    (fields: name, last_name, phone, email, source).
{%- endcomment -%}

{%- comment -%}
  All display copy comes from locale files (locales/*.json under "waitlist")
  so it's translatable in Translate & Adapt. Referral <option> values stay a
  stable English tag ("waitlist, doctor") regardless of language, so admin
  filtering doesn't break; only the visible label is localized.
{%- endcomment -%}
{%- liquid
  assign action = settings.waitlist_form_action
-%}

<div id="gh-waitlist-modal" class="gh-modal" role="dialog" aria-modal="true" aria-labelledby="gh-modal-title" hidden>
  <div class="gh-modal__overlay" data-gh-waitlist-close></div>
  <div class="gh-modal__panel" role="document">
    <button type="button" class="gh-modal__close" data-gh-waitlist-close aria-label="Close">&times;</button>

    <p class="gh-modal__eyebrow">{{ 'waitlist.eyebrow' | t }}</p>
    <h2 id="gh-modal-title" class="gh-modal__title">{{ 'waitlist.title' | t }}</h2>
    <p class="gh-modal__sub">{{ 'waitlist.subtitle' | t }}</p>

    {%- capture fields -%}
      <div class="gh-field-row">
        <label class="gh-field">
          <span class="gh-field__label">{{ 'waitlist.first_name' | t }}</span>
          <input type="text" name="{% if action == blank %}contact[first_name]{% else %}name{% endif %}" required autocomplete="given-name">
        </label>
        <label class="gh-field">
          <span class="gh-field__label">{{ 'waitlist.last_name' | t }}</span>
          <input type="text" name="{% if action == blank %}contact[last_name]{% else %}last_name{% endif %}" required autocomplete="family-name">
        </label>
      </div>
      <label class="gh-field">
        <span class="gh-field__label">{{ 'waitlist.phone' | t }}</span>
        <input type="tel" {% if action == blank %}data-gh-phone{% else %}name="phone"{% endif %} required autocomplete="tel" inputmode="tel" placeholder="81 1234 5678">
      </label>
      <label class="gh-field">
        <span class="gh-field__label">{{ 'waitlist.email' | t }}</span>
        <input type="email" name="{% if action == blank %}contact[email]{% else %}email{% endif %}" required autocomplete="email">
      </label>
      <label class="gh-field">
        <span class="gh-field__label">{{ 'waitlist.source_label' | t }}</span>
        <select {% if action == blank %}name="contact[tags]" data-gh-source{% else %}name="source"{% endif %}>
          <option value="{% if action == blank %}waitlist, doctor{% else %}A doctor{% endif %}">{{ 'waitlist.source_doctor' | t }}</option>
          <option value="{% if action == blank %}waitlist, nutritionist{% else %}A nutritionist{% endif %}">{{ 'waitlist.source_nutritionist' | t }}</option>
          <option value="{% if action == blank %}waitlist, instagram{% else %}Instagram{% endif %}">{{ 'waitlist.source_instagram' | t }}</option>
          <option value="{% if action == blank %}waitlist, friend{% else %}Friend or family{% endif %}">{{ 'waitlist.source_friend' | t }}</option>
          <option value="{% if action == blank %}waitlist, google{% else %}Google{% endif %}">{{ 'waitlist.source_google' | t }}</option>
          <option value="{% if action == blank %}waitlist, location{% else %}I saw the location{% endif %}">{{ 'waitlist.source_location' | t }}</option>
          <option value="{% if action == blank %}waitlist, other{% else %}Other{% endif %}" data-gh-other>{{ 'waitlist.source_other' | t }}</option>
        </select>
      </label>
      <label class="gh-field gh-field--other" data-gh-other-field hidden>
        <span class="gh-field__label">{{ 'waitlist.other_label' | t }}</span>
        <input type="text" {% if action == blank %}data-gh-other-input{% else %}name="source_other"{% endif %} autocomplete="off" placeholder="{{ 'waitlist.other_placeholder' | t }}">
      </label>
      <button type="submit" class="gh-btn gh-btn--solid gh-modal__submit">{{ 'waitlist.submit' | t }}</button>
    {%- endcapture -%}

    {%- if action == blank -%}
      {%- form 'customer', class: 'gh-modal__form' -%}
        <input type="hidden" name="contact[note]" value="Galim waitlist signup" data-gh-note>
        {%- if form.posted_successfully? -%}
          <p class="gh-modal__success">{{ 'waitlist.success' | t }}</p>
        {%- else -%}
          {%- if form.errors -%}
            <p class="gh-modal__error">{{ form.errors | default_errors }}</p>
          {%- endif -%}
          {{ fields }}
        {%- endif -%}
      {%- endform -%}
    {%- else -%}
      <form action="{{ action }}" method="post" class="gh-modal__form" accept-charset="UTF-8">
        {{ fields }}
      </form>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .gh-modal[hidden] { display: none !important; }
  .gh-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .gh-modal.is-open { opacity: 1; }
  .gh-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(6, 31, 38, 0.72);
    backdrop-filter: blur(6px);
  }
  .gh-modal__panel {
    position: relative;
    width: 100%;
    max-width: 480px;
    max-height: calc(100vh - 48px);
    overflow-y: auto;
    background: linear-gradient(160deg, var(--gh-teal-700), var(--gh-bg-900));
    border: 1px solid var(--gh-border-strong);
    border-radius: 16px;
    padding: 44px 40px 40px;
    transform: translateY(12px) scale(0.98);
    transition: transform 0.25s ease;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
  }
  .gh-modal.is-open .gh-modal__panel { transform: translateY(0) scale(1); }
  .gh-modal__close {
    position: absolute;
    top: 16px;
    right: 18px;
    background: none;
    border: 0;
    color: var(--gh-muted);
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
  }
  .gh-modal__close:hover { color: var(--gh-light); }
  .gh-modal__eyebrow { font: 500 11px/1 var(--gh-mono); letter-spacing: 0.24em; color: var(--gh-green); margin-bottom: 16px; }
  .gh-modal__title { font: 200 34px/1.05 var(--gh-sans); letter-spacing: -0.02em; color: var(--gh-white); margin-bottom: 8px; }
  .gh-modal__sub { font: 300 16px/1.5 var(--gh-sans); color: var(--gh-muted); margin-bottom: 28px; }
  .gh-modal__form { display: flex; flex-direction: column; gap: 16px; }
  .gh-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .gh-field { display: flex; flex-direction: column; gap: 7px; }
  .gh-field__label { font: 500 11px/1 var(--gh-mono); letter-spacing: 0.12em; text-transform: uppercase; color: var(--gh-slate); }
  .gh-field input,
  .gh-field select {
    background: rgba(6, 31, 38, 0.5);
    border: 1px solid var(--gh-border);
    border-radius: 4px;
    padding: 13px 14px;
    color: var(--gh-light);
    font: 400 15px/1.2 var(--gh-sans);
    width: 100%;
  }
  .gh-field input::placeholder { color: var(--gh-slate); }
  .gh-field input:focus,
  .gh-field select:focus { outline: none; border-color: var(--gh-green); }
  .gh-field select { appearance: none; cursor: pointer; }
  .gh-modal__submit { width: 100%; justify-content: center; margin-top: 8px; }
  .gh-modal__success { font: 400 17px/1.5 var(--gh-sans); color: var(--gh-green); }
  .gh-modal__error { font: 400 14px/1.5 var(--gh-sans); color: #e8a0a0; margin-bottom: 16px; }
  @media (max-width: 768px) {
    .gh-modal { padding: 14px; }
    .gh-modal__panel { padding: 36px 22px 28px; }
    .gh-modal__title { font-size: 28px; }
    .gh-field-row { grid-template-columns: 1fr; gap: 16px; }
  }
{% endstylesheet %}
